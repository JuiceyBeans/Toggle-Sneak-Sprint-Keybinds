	"authors": [
		"JuiceyBeans"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/toggle-sneak-crouch-keybinds/",
		"sources": "https://github.com/JuiceyBeans/Toggle-Sneak-Crouch-Keybinds"
	},
	"license": "GNU LGPL 3.0",
	"icon": "assets/tsac/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.juiceybeans.tsac.ToggleSneakCrouch"
		],
		"client": [
			"com.juiceybeans.tsac.client.ToggleSneakCrouchClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
